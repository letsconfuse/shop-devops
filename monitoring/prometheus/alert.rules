groups:
- name: sock-shop.rules
  rules:
  - alert: FrontEndDown
    expr: up{job="front-end"} == 0
    for: 1m
    labels:
      severity: critical
    annotations:
      summary: "Front-End service is down"
      description: "The front-end UI service has been unreachable for more than 1 minute."

  - alert: HighErrorRate
    expr: rate(request_duration_seconds_count{status_code=~"5.."}[5m]) > 0.05
    for: 1m
    labels:
      severity: warning
    annotations:
      summary: "High HTTP 5xx error rate"
      description: "More than 5% of requests to a service are returning 5xx errors."
